APP_NAME="AGBS LIBRARY"
BASE_URL="http://localhost:3000"
PORT=3000
SESSION_SECRET="replace-with-a-long-random-value"

# First admin is seeded by email only. Set their password inside the app after first login setup.
ADMIN_EMAIL="agbsindia2020@gmail.com"

# Optional emergency admin login for serverless preview before storage is configured.
# Set this in Vercel Project Settings > Environment Variables, never in code.
ADMIN_BOOTSTRAP_PASSWORD=""

# Production storage for uploads and app records.
# AWS S3 keeps every PDF/EPUB/image as one object under books/.
# It also stores the app's small JSON records under data/ when these values are set.
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="agbs-library-books-india-567681717467-us-east-1-an"
AWS_S3_PREFIX="agbs-library"
AWS_STORAGE_BUDGET_GB="1500"
AWS_STORAGE_PLAN_MONTHS="24"

# Optional Google OAuth. Keep both values secret in deployment settings.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/auth/google/callback"

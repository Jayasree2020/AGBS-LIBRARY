APP_NAME="AGBS LIBRARY"
BASE_URL="http://localhost:3000"
PORT=3000
SESSION_SECRET="replace-with-a-long-random-value"

# Use MongoDB Atlas in production. If omitted, the app runs with local JSON storage for preview.
MONGODB_URI=""
MONGODB_DB="seminary_library"

# First admin is seeded by email only. Set their password inside the app after first login setup.
ADMIN_EMAIL="agbsindia2020@gmail.com"

# Optional emergency admin login for serverless preview before MongoDB is configured.
# Set this in Vercel Project Settings > Environment Variables, never in code.
ADMIN_BOOTSTRAP_PASSWORD=""

# Preferred no-Mongo storage for production uploads.
# Cloudflare R2 keeps every PDF/EPUB/image as one object under books/.
# It also stores the app's small JSON records under data/ when these values are set.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="agbs-library-books"
R2_PREFIX="agbs-library"

# Optional Google OAuth. Keep both values secret in deployment settings.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/auth/google/callback"
